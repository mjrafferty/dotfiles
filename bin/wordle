#! /usr/bin/env bash

readonly ARGA=("$@")
readonly WORD_LIST="${HOME}/wordle.txt"

# Main
main () {
  local option letter 
  local -a matches likely_letters guesses new_guesses
  local one='.' two='.' three='.' four='.' five='.' no=" " yes_str="a-z"
  local -a yes=(. . . . .)

  while getopts "1:2:3:4:5:y:n:" option "${ARGA[@]}"; do
    case $option in
      1) one="${OPTARG}"; yes+=("${OPTARG}") ;;
      2) two="${OPTARG}"; yes+=("${OPTARG}") ;;
      3) three="${OPTARG}"; yes+=("${OPTARG}") ;;
      4) four="${OPTARG}"; yes+=("${OPTARG}") ;;
      5) five="${OPTARG}"; yes+=("${OPTARG}") ;;
      n) no="${OPTARG}" ;;
      y) index=0; yes_str="";
        for letter in ${OPTARG//[a-z]/& }; do
          yes[index]=$letter
          yes_str+="$letter"
          (( index+=1 ))
        done
        ;;
      "?")
        echo "-${OPTARG} is not a supported option." >&2
        ;;
      *);;
    esac
  done

  mapfile -t matches < <(
    grep -v "[${no}]" "${WORD_LIST}" \
      | grep "${yes[0]}" \
      | grep "${yes[1]}" \
      | grep "${yes[2]}" \
      | grep "${yes[3]}" \
      | grep "${yes[4]}" \
      | grep "^${one}${two}${three}${four}${five}$"
    )

  printf "Word List\n==========\n"
  printf "%s\n" "${matches[@]}"
  echo

  mapfile -t likely_letters < <(
    for letter in {a..z}; do
      printf "%s\t" "${letter}";
      grep -c "$letter" <(printf "%s\n" "${matches[@]}")
    done \
      | grep -v "[${yes[*]}]" \
      | grep -v -- "[^0-9]0 *$" \
      | sort -k2nr \
      | awk '{print $1}'
    )

  if [[ "${#likely_letters[@]}" -gt 2 ]]; then
    printf "Remaining Letters: %s\n\n" "${likely_letters[*]}"

    mapfile -t guesses < <(grep "[${yes_str}]" "${WORD_LIST}")

    for letter in "${likely_letters[@]}"; do
      mapfile -t new_guesses < <(printf "%s\n" "${guesses[@]}" | grep "$letter")
      [[ ${#new_guesses[@]} -gt 0 ]] && guesses=("${new_guesses[@]}")
    done

    printf "Suggested Guesses\n=============\n"
    printf "%s\n" "${guesses[@]}"
  fi
}

main
